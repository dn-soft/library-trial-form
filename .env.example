# API base URL for Argong-books server (POST /trial-applications endpoint)
# Local dev default: http://localhost:3002 (Argong-books main.ts uses port 3002)
# Copy to .env.local for local override.
VITE_API_BASE=http://localhost:3002

# Google reCAPTCHA v3 site key (public — safe to expose in client bundle).
# Register the domain at https://www.google.com/recaptcha/admin (type: v3).
# Add 'localhost' to the domain list for local dev.
# Leave unset in dev — the server will also skip verification when
# RECAPTCHA_SECRET_KEY is unset.
# NOTE: the *secret* key belongs ONLY on the backend (RECAPTCHA_SECRET_KEY).
# Never place it in this file — it will be bundled and leak to browsers.
VITE_RECAPTCHA_SITE_KEY=